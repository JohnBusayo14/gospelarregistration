# Frontend environment variables for the gospelar registration SPA.
# Copy to .env.local for dev; set the same keys in Vercel for prod.
# All VITE_* vars are baked into the bundle at build time — redeploy after changes.

# Google OAuth Web Client ID (same value as backend GOOGLE_CLIENT_ID's web entry).
# Without this, the Login page shows a "not configured" warning instead of the
# Google button. See src/pages/Login.jsx.
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL.
#   Leave blank for local dev (auto-detects localhost:5000) and for
#   production (defaults to https://api.gospelar.com). Set explicitly only
#   when overriding for staging / preview environments (e.g. pointing the
#   Vercel preview deploy at a Railway preview backend). See src/api.js.
VITE_API_BASE=
